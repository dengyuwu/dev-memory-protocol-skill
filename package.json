{
  "name": "vbm-skill",
  "private": true,
  "version": "0.1.0",
  "description": "Vibe Memory (vbm) skill for Codex and Claude Code",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "install:auto": "node ./skills/vbm/scripts/setup.mjs --project .",
    "install:codex": "node ./skills/vbm/scripts/setup.mjs --tool codex --project .",
    "install:claude": "node ./skills/vbm/scripts/setup.mjs --tool claude --project .",
    "install:both": "node ./skills/vbm/scripts/setup.mjs --tool both --project .",
    "install:base": "node ./skills/vbm/scripts/install.mjs --project .",
    "install:enable": "node ./skills/vbm/scripts/post-install.mjs --project .",
    "install:global": "node ./skills/vbm/scripts/install-global.mjs",
    "install:claude-hooks": "node ./skills/vbm/scripts/install-claude-hooks.mjs --scope user",
    "uninstall:auto": "node ./skills/vbm/scripts/remove.mjs --project .",
    "uninstall:codex": "node ./skills/vbm/scripts/remove.mjs --tool codex --project .",
    "uninstall:claude": "node ./skills/vbm/scripts/remove.mjs --tool claude --project .",
    "uninstall:both": "node ./skills/vbm/scripts/remove.mjs --tool both --project .",
    "uninstall:base": "node ./skills/vbm/scripts/uninstall.mjs --project .",
    "uninstall:global": "node ./skills/vbm/scripts/uninstall-global.mjs",
    "uninstall:claude-hooks": "node ./skills/vbm/scripts/uninstall-claude-hooks.mjs --scope user",
    "recall": "node ./skills/vbm/scripts/recall.mjs --project .",
    "capture:diff": "node ./skills/vbm/scripts/capture-from-diff.mjs --project .",
    "capture:auto": "node ./skills/vbm/scripts/auto-capture.mjs --project .",
    "session:close": "node ./skills/vbm/scripts/session-close.mjs --project .",
    "index": "node ./skills/vbm/scripts/index.mjs --project .",
    "compact": "node ./skills/vbm/scripts/compact.mjs --project ."
  }
}
